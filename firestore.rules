rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // jew / main / user / {문서} — 앱과 lib/jewUserFirestore.ts 의 JEW_USER_PARENT_DOC_ID 와 맞춤
    match /jew/{jewParent}/user/{userId} {
      allow create: if jewParent == 'main'
        && isValidJewUserCreate();

      allow update: if jewParent == 'main'
        && isValidJewUserHitUpdate();

      // 실시간 랭킹용 목록 조회 (이름·hitCount만 클라이언트에 노출)
      allow read: if jewParent == 'main';

      allow delete: if false;
    }

    // coupon 컬렉션: 모두 읽기 허용, used 필드만 업데이트 허용
    match /coupon/{document} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used']);
      allow create, delete: if false;
    }

    // letter 컬렉션: 읽기/쓰기 모두 허용
    match /letter/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // 그 외 컬렉션은 기본적으로 다 막기
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function isValidJewUserCreate() {
  let data = request.resource.data;
  let keysOk = data.keys().hasOnly(['name'])
    || data.keys().hasOnly(['name', 'createdAt'])
    || data.keys().hasOnly(['name', 'createdAt', 'hitCount']);
  let hitOk = !('hitCount' in data)
    || (data.hitCount is int && data.hitCount == 0);
  return keysOk
    && hitOk
    && data.name is string
    && data.name.size() >= 1
    && data.name.size() <= 32;
}

function isValidJewUserHitUpdate() {
  let diff = request.resource.data.diff(resource.data);
  return diff.affectedKeys().hasOnly(['hitCount'])
    && request.resource.data.hitCount is int
    && request.resource.data.hitCount >= 0;
}
