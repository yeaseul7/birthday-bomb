rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // jew / main / user / {문서} — 앱과 lib/jewUserFirestore.ts 의 JEW_USER_PARENT_DOC_ID 와 맞춤
    match /jew/{jewParent}/user/{userId} {
      allow create: if jewParent == 'main'
        && isValidJewUserCreate();

      allow update: if jewParent == 'main'
        && isValidJewUserHitUpdate();

      // 실시간 랭킹용 목록 조회 (이름·hitCount만 클라이언트에 노출)
      allow read: if jewParent == 'main';

      allow delete: if false;
    }

    // jew / main / letter — 편지 (userName, userDocId, content, createdAt)
    match /jew/{jewParent}/letter/{letterId} {
      allow read: if jewParent == 'main';

      allow create: if jewParent == 'main'
        && isValidJewLetterCreate();

      allow update, delete: if false;
    }

    // jew / main / special / totals — 전역 powCount, cakeCount (lib/jewSpecialCounters.ts)
    match /jew/{jewParent}/special/{docId} {
      allow read: if jewParent == 'main';

      allow create, update: if jewParent == 'main'
        && docId == 'totals'
        && isValidJewSpecialCountersWrite();

      allow delete: if false;
    }

    // coupon 컬렉션: 모두 읽기 허용, used 필드만 업데이트 허용
    match /coupon/{document} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used']);
      allow create, delete: if false;
    }

    // 그 외 컬렉션은 기본적으로 다 막기
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function isValidJewUserCreate() {
  let data = request.resource.data;
  let keysOk = data.keys().hasOnly(['name'])
    || data.keys().hasOnly(['name', 'createdAt'])
    || data.keys().hasOnly(['name', 'createdAt', 'hitCount']);
  let hitOk = !('hitCount' in data)
    || (data.hitCount is int && data.hitCount == 0);
  return keysOk
    && hitOk
    && data.name is string
    && data.name.size() >= 1
    && data.name.size() <= 32;
}

function isValidJewUserHitUpdate() {
  let diff = request.resource.data.diff(resource.data);
  return diff.affectedKeys().hasOnly(['hitCount'])
    && request.resource.data.hitCount is int
    && request.resource.data.hitCount >= 0;
}

function isValidJewSpecialCountersWrite() {
  let d = request.resource.data;
  let keysOk = d.keys().hasOnly(['powCount'])
    || d.keys().hasOnly(['cakeCount'])
    || d.keys().hasOnly(['powCount', 'cakeCount']);
  let powOk = !d.keys().hasAny(['powCount'])
    || (d.powCount is int && d.powCount >= 0 && d.powCount < 100000000);
  let cakeOk = !d.keys().hasAny(['cakeCount'])
    || (d.cakeCount is int && d.cakeCount >= 0 && d.cakeCount < 100000000);
  return keysOk && powOk && cakeOk;
}

function isValidJewLetterCreate() {
  let d = request.resource.data;
  return d.keys().hasOnly(['userName', 'userDocId', 'content', 'createdAt'])
    && d.userName is string
    && d.userName.size() >= 0
    && d.userName.size() <= 64
    && d.userDocId is string
    && d.userDocId.size() >= 0
    && d.userDocId.size() <= 128
    && d.content is string
    && d.content.size() >= 1
    && d.content.size() <= 1000;
}
